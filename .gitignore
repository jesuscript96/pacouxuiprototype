/lang/vendor/**
!/lang/vendor/filament-actions/
!/lang/vendor/filament-actions/**
!/lang/vendor/filament-panels/
!/lang/vendor/filament-panels/**
!/lang/vendor/filament-forms/
!/lang/vendor/filament-forms/**
/public/vendor/
/resources/views/vendor/
/resources/views/errors/
!/resources/views/errors/403.blade.php
/stubs/
/sail
/docker
/routes/ai.php
/resources/views/mcp/
env.admin
env.cliente

# Clockwork (debug local; el índice y los .json se regeneran)
/storage/clockwork/
/storage/clockwork/*
!/storage/clockwork/.gitignore
