# ===========================================
.DS_Store
Thumbs.db
*.log
Homestead.json
Homestead.yaml
Vagrantfile
.terraform/
*.tfstate
*.tfstate.*
Thumbs.db
/database/testing.sqlite

/storage/app/public/uploads
/storage/app/public/uploads/*
/public/assets/*
/public/assets/companies/*

# ===========================================
# Publicaciones de paquetes (regenerables con vendor:publish)
# ===========================================
