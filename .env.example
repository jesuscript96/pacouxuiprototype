APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Demo enseñable (tras seeders prototipo): cliente@tecben.com / password → /cliente/login o /admin/login (ambos redirigen al panel cliente).

# Módulo (dejar vacío en desarrollo = un solo servidor con ambos paneles)
# En producción/CI: admin o cliente según el servidor.
APP_MODULE=

# Prototipo: el panel cliente no usa login (usuario demo). Opcional para futuros flags.
PROTOTIPO_AUTO_LOGIN=true

# URLs de los paneles (solo necesarias si usas redirecciones entre servidores)
# Desarrollo (un servidor): mismo origen que APP_URL
ADMIN_URL="${APP_URL}/admin"
CLIENTE_URL="${APP_URL}/cliente"
# QA/Producción (dos servidores): descomentar y ajustar
# APP_MODULE=admin
# ADMIN_URL=http://localhost:8000/admin
# CLIENTE_URL=http://localhost:8001/cliente

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Varios workers del servidor embebido: requiere `php artisan serve --no-reload` (si no, Laravel avisa y usa 1 worker).
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database + `php artisan queue:work` (o `composer run dev`). En Windows, si php.ini tiene max_execution_time=60,
# arranca serve/worker con: php -d max_execution_time=0 artisan …
# Opcional solo local: sync (luego `php artisan config:clear`) — importaciones pesadas necesitan tiempo; ver set_time_limit en jobs.
QUEUE_CONNECTION=database
# Colas usadas por la app: default, notificaciones (push). Worker: php artisan queue:work --queue=notificaciones,default

# ============================================
# SCHEDULER / CRON
# ============================================
# En el servidor (ejemplo):
# * * * * * cd /ruta/al/proyecto && php artisan schedule:run >> /dev/null 2>&1
#
# Comandos programados (ver también routes/console.php):
# - notificaciones:enviar-programadas (cada 5 min)
# - bajas:procesar-programadas (diario 00:25)

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@paco.app"
MAIL_FROM_NAME="${APP_NAME}"

# Correo de bienvenida / config Paco
PACO_APP_DOWNLOAD_LINK="https://paco.app/download"
PACO_SUPPORT_EMAIL="soporte@paco.app"

# =============================================================================
# ARCHIVOS (ArchivoService)
# =============================================================================
# Disco para archivos: 'uploads' (local) o 's3' (Wasabi)
ARCHIVOS_DISK=uploads

# Wasabi S3 (cuando ARCHIVOS_DISK=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=https://s3.us-east-1.wasabisys.com
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

# ========================================
# WORKOS SSO
# ========================================
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URL="${APP_URL}/auth/workos/callback"

# ========================================
# Tableau (informes incrustados — panel Cliente → Analíticos)
# ========================================
TABLEAU_URL=
TABLEAU_CLIENT_ID=
TABLEAU_SECRET_ID=
TABLEAU_SECRET_KEY=
# Usuario Tableau para embed en panel Admin (default: admin@paco.app)
# TABLEAU_EMBED_ADMIN_USERNAME=admin@paco.app
# Opcional: vigencia del JWT en minutos (por defecto 10)
# TABLEAU_TOKEN_TTL_MINUTES=10
# Opcional: URL del script Embedding API v3 si tu región difiere
# TABLEAU_EMBEDDING_SCRIPT_URL=https://us-east-1.online.tableau.com/javascripts/api/tableau.embedding.3.latest.min.js
# Empresa con vista alternativa de rotación (legacy Palacio de Hierro)
# TABLEAU_PALACIO_HIERRO_EMPRESA_ID=54

# ========================================
# Pumble (webhook temporal para registro de notificaciones push)
# ========================================
PUMBLE_WEBHOOK_URL=
PUMBLE_NOTIFICATIONS_ENABLED=false

# =============================================================================
# VALIDACIÓN DOCUMENTAL (Fase 9 — pendiente de accesos)
# =============================================================================

# Nubarium (INE, CSF, biometría, IMSS, firma NOM-151)
NUBARIUM_USER=
NUBARIUM_PASSWORD=
OCR_NUBARIUM=
INE_NUBARIUM=
CSF_NUBARIUM=
BIOMETRICS_NUBARIUM=
NUBARIUM_IMSS_URL=https://api.nubarium.com/imss/wh/v1
NUBARIUM_NOM151_URL=https://firma.nubarium.com/nom151/v1/obtener-nom151

# OpenAI (Comprobante domicilio con gpt-4.1, CV con gpt-4o)
OPENAI_BASE_URL=
OPENAI_KEY=

# CURP (opcional — hay algoritmo local en CurpService)
API_VALIDA_CURP=
API_VALIDA_CURP_TOKEN=

# =============================================================================
# HISTORIAL LABORAL IMSS (Fase 10 — pendiente de accesos)
# =============================================================================

# Palenca (Buró de Ingresos)
PALENCA_URL=
PALENCA_KEY_PRIVATE=
PALENCA_KEY_PUBLIC=
PALENCA_WEBHOOK_USER=
PALENCA_WEBHOOK_PASSWORD=
